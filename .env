# ==============================
# PawPick 環境設定
# ==============================

PORT=3000
NODE_ENV=development

# JWT 密鑰（上線前請改成隨機長字串）
JWT_SECRET=pawpick_super_secret_key_please_change_in_production_2025

# 資料庫
DB_PATH=./database/pawpick.db

# 上傳路徑
UPLOAD_PATH=./uploads

# 前台網址（CORS 用）
FRONTEND_URL=http://localhost:5500

# ==============================
# 綠界 ECPay 金流設定
# ==============================
# 測試帳號（預設，直接可用）
# 申請正式帳號：https://www.ecpay.com.tw
ECPAY_MERCHANT_ID=2000132
ECPAY_HASH_KEY=5294y06JbISpM5x9
ECPAY_HASH_IV=v77hoKGq4kWxNNIS

# 付款通知網址（本機測試需用 ngrok，上線後改為正式網址）
ECPAY_RETURN_URL=http://localhost:3000/api/payment/notify
ECPAY_RESULT_URL=http://localhost:3000/api/payment/result

# ==============================
# 正式上線時改為：
# NODE_ENV=production
# FRONTEND_URL=https://你的前台網址
# ECPAY_MERCHANT_ID=正式商店代號
# ECPAY_HASH_KEY=正式HashKey
# ECPAY_HASH_IV=正式HashIV
# ECPAY_RETURN_URL=https://你的API網址/api/payment/notify
# ECPAY_RESULT_URL=https://你的API網址/api/payment/result
# ==============================
