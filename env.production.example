PORT=3000
NODE_ENV=production

# ⚠️ 請換成強密碼（至少 32 個隨機字元）
JWT_SECRET=請換成你的強密碼_至少32字元_例如用openssl_rand_base64_32產生

# 資料庫路徑（掛載到 /mnt/data 目錄）
DB_PATH=/mnt/data/pawpick.db

# 圖片上傳路徑（掛載到 /mnt/data/uploads）
UPLOAD_PATH=/mnt/data/uploads

# 你的前台網址（Firebase Hosting 網址）
FRONTEND_URL=https://你的專案ID.web.app

# ==============================
# 綠界 ECPay 正式設定
# ==============================
ECPAY_MERCHANT_ID=你的正式商店代號
ECPAY_HASH_KEY=你的正式HashKey
ECPAY_HASH_IV=你的正式HashIV

# Cloud Run 服務的公開 HTTPS 網址
ECPAY_RETURN_URL=https://你的CloudRun網址/api/payment/notify
ECPAY_RESULT_URL=https://你的CloudRun網址/api/payment/result
